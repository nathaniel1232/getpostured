<style>
  .product-section {
    padding: 80px 20px;
    background: #0B0B0B;
  }

  .product-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    max-width: 1200px;
    margin: 0 auto;
    align-items: start;
  }

  /* ---------- Gallery ---------- */
  .product-gallery {
    position: sticky;
    top: 100px;
  }

  .product-main-image {
    width: 100%;
    aspect-ratio: 1 / 1;
    background: #1a1a1a;
    border-radius: 8px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 12px;
  }

  .product-main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-main-image__placeholder {
    color: rgba(255, 255, 255, 0.35);
    font-family: var(--font-heading, 'Arial Black', sans-serif);
    font-size: 0.9rem;
    letter-spacing: 0.05em;
  }

  .product-thumbnails {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding-bottom: 4px;
  }

  .product-thumbnails button {
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    padding: 0;
    border: 2px solid transparent;
    border-radius: 6px;
    overflow: hidden;
    background: #1a1a1a;
    cursor: pointer;
    transition: border-color 0.25s ease;
  }

  .product-thumbnails button.active {
    border-color: #C8A24E;
  }

  .product-thumbnails button:hover {
    border-color: rgba(200, 162, 78, 0.5);
  }

  .product-thumbnails button img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ---------- Product Info ---------- */
  .product-info {
    color: #FFFFFF;
  }

  .product-info__title {
    font-family: var(--font-heading, 'Arial Black', sans-serif);
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    margin: 0 0 12px;
    line-height: 1.2;
  }

  .product-info__rating {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 20px;
  }

  .product-info__stars {
    display: flex;
    gap: 2px;
    color: #C8A24E;
    font-size: 1rem;
  }

  .product-info__review-count {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.85rem;
  }

  .product-info__price {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 24px;
    flex-wrap: wrap;
  }

  .product-info__compare-price {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.4);
    text-decoration: line-through;
  }

  .product-info__current-price {
    font-family: var(--font-heading, 'Arial Black', sans-serif);
    font-size: 1.6rem;
    font-weight: 700;
    color: #FFFFFF;
  }

  .product-info__description {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 28px;
  }

  .product-features {
    list-style: none;
    padding: 0;
    margin: 0 0 32px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .product-features li {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.9rem;
    line-height: 1.5;
  }

  .product-features__check {
    color: #C8A24E;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* ---------- Size Selector ---------- */
  .size-selector {
    margin-bottom: 24px;
  }

  .size-selector__label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 10px;
  }

  .size-selector__options {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .size-option {
    min-width: 52px;
    padding: 10px 18px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 6px;
    background: transparent;
    color: rgba(255, 255, 255, 0.7);
    font-family: var(--font-heading, 'Arial Black', sans-serif);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: all 0.25s ease;
    text-align: center;
  }

  .size-option:hover {
    border-color: rgba(200, 162, 78, 0.5);
    color: #FFFFFF;
  }

  .size-option.active {
    border-color: #C8A24E;
    background: rgba(200, 162, 78, 0.12);
    color: #FFFFFF;
  }

  /* ---------- Quantity Selector ---------- */
  .quantity-selector {
    display: flex;
    align-items: center;
    margin-bottom: 24px;
  }

  .quantity-selector__label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.6);
    margin-right: 14px;
  }

  .qty-minus,
  .qty-plus {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background: transparent;
    color: #FFFFFF;
    font-size: 1.1rem;
    cursor: pointer;
    transition: border-color 0.25s ease;
  }

  .qty-minus {
    border-radius: 6px 0 0 6px;
  }

  .qty-plus {
    border-radius: 0 6px 6px 0;
  }

  .qty-minus:hover,
  .qty-plus:hover {
    border-color: #C8A24E;
  }

  .qty-input {
    width: 52px;
    height: 40px;
    text-align: center;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-left: none;
    border-right: none;
    background: transparent;
    color: #FFFFFF;
    font-family: var(--font-heading, 'Arial Black', sans-serif);
    font-size: 0.95rem;
    -moz-appearance: textfield;
  }

  .qty-input::-webkit-outer-spin-button,
  .qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  /* ---------- Add to Cart ---------- */
  .add-to-cart-form .btn-primary.btn-full {
    display: block;
    width: 100%;
    padding: 16px 32px;
    background: #C8A24E;
    color: #0B0B0B;
    font-family: var(--font-heading, 'Arial Black', sans-serif);
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.2s ease;
    text-align: center;
  }

  .add-to-cart-form .btn-primary.btn-full:hover {
    background: #d4af5a;
    transform: translateY(-1px);
  }

  .add-to-cart-form .btn-primary.btn-full:active {
    transform: translateY(0);
  }

  .product-info__secure {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 14px;
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.75rem;
    letter-spacing: 0.04em;
  }

  .product-info__secure svg {
    flex-shrink: 0;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 768px) {
    .product-section {
      padding: 48px 16px;
    }

    .product-grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .product-gallery {
      position: static;
    }

    .product-info__title {
      font-size: 1.6rem;
    }

    .product-info__current-price {
      font-size: 1.35rem;
    }

    .product-thumbnails button {
      width: 60px;
      height: 60px;
    }
  }
</style>

{%- assign product = section.settings.product -%}

<section class="product-section" id="product-section">
  <div class="product-grid">

    <!-- ========== Image Gallery ========== -->
    <div class="product-gallery">
      <div class="product-main-image">
        {%- if product != blank and product.featured_image -%}
          <img
            src="{{ product.featured_image | image_url: width: 800 }}"
            alt="{{ product.featured_image.alt | escape }}"
            loading="eager"
            width="800"
            id="main-product-image"
          >
        {%- else -%}
          <span class="product-main-image__placeholder" id="main-product-image">No product image</span>
        {%- endif -%}
      </div>

      {%- if product != blank and product.images.size > 1 -%}
        <div class="product-thumbnails">
          {%- for image in product.images -%}
            <button
              type="button"
              class="product-thumbnail{% if forloop.first %} active{% endif %}"
              data-full-src="{{ image | image_url: width: 800 }}"
              aria-label="View image {{ forloop.index }}"
            >
              <img
                src="{{ image | image_url: width: 150 }}"
                alt="{{ image.alt | escape }}"
                loading="lazy"
                width="150"
                height="150"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <!-- ========== Product Info ========== -->
    <div class="product-info">
      <h2 class="product-info__title">
        {%- if product != blank -%}
          {{ product.title }}
        {%- else -%}
          FrameFix Strap™
        {%- endif -%}
      </h2>

      <div class="product-info__rating">
        <span class="product-info__stars" aria-hidden="true">★★★★★</span>
        <span class="product-info__review-count">(127 reviews)</span>
      </div>

      <div class="product-info__price">
        {%- if product != blank -%}
          {%- if section.settings.show_compare_price and product.compare_at_price > product.price -%}
            <span class="product-info__compare-price">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
          <span class="product-info__current-price">{{ product.price | money }}</span>
        {%- else -%}
          <span class="product-info__compare-price">$79.99</span>
          <span class="product-info__current-price">$49.99</span>
        {%- endif -%}
      </div>

      <div class="product-info__description">
        {%- if section.settings.description_override != blank -%}
          {{ section.settings.description_override }}
        {%- elsif product != blank and product.description != blank -%}
          {{ product.description }}
        {%- else -%}
          <p>The FrameFix Strap™ is a premium posture corrector designed for all-day comfort. Engineered with breathable materials and an adjustable fit system to support your spine naturally.</p>
        {%- endif -%}
      </div>

      <!-- Feature List -->
      <ul class="product-features">
        {%- if section.blocks.size > 0 -%}
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' -%}
              <li {{ block.shopify_attributes }}>
                <span class="product-features__check">{{ block.settings.icon }}</span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          <li><span class="product-features__check">✓</span><span>Adjustable fit — works for all body types</span></li>
          <li><span class="product-features__check">✓</span><span>Breathable, lightweight material</span></li>
          <li><span class="product-features__check">✓</span><span>Wear under or over clothing</span></li>
          <li><span class="product-features__check">✓</span><span>Free Posture Mastery Course included</span></li>
          <li><span class="product-features__check">✓</span><span>30-day money-back guarantee</span></li>
        {%- endif -%}
      </ul>

      <!-- Size Selector -->
      <div class="size-selector">
        <span class="size-selector__label">Size</span>
        <div class="size-selector__options">
          {%- if product != blank and product.variants.size > 1 -%}
            {%- for variant in product.variants -%}
              <button
                type="button"
                class="size-option{% if forloop.first %} active{% endif %}"
                data-variant-id="{{ variant.id }}"
                aria-label="Select {{ variant.title }}"
              >
                {{ variant.title }}
              </button>
            {%- endfor -%}
          {%- else -%}
            <button type="button" class="size-option active" data-variant-id="" aria-label="Select S">S</button>
            <button type="button" class="size-option" data-variant-id="" aria-label="Select M">M</button>
            <button type="button" class="size-option" data-variant-id="" aria-label="Select L">L</button>
            <button type="button" class="size-option" data-variant-id="" aria-label="Select XL">XL</button>
          {%- endif -%}
        </div>
      </div>

      <!-- Quantity Selector -->
      <div class="quantity-selector">
        <span class="quantity-selector__label">Qty</span>
        <button type="button" class="qty-minus" aria-label="Decrease quantity">−</button>
        <input type="number" class="qty-input" value="1" min="1" max="99" aria-label="Quantity">
        <button type="button" class="qty-plus" aria-label="Increase quantity">+</button>
      </div>

      <!-- Add to Cart -->
      <form class="add-to-cart-form" action="/cart/add" method="post">
        {%- if product != blank and product.first_available_variant -%}
          <input type="hidden" name="id" value="{{ product.first_available_variant.id }}">
        {%- else -%}
          <input type="hidden" name="id" value="">
        {%- endif -%}
        <input type="hidden" name="quantity" value="1">
        <button type="submit" class="btn-primary btn-full">Add to Cart</button>
      </form>

      <div class="product-info__secure">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
        <span>Secure checkout · SSL encrypted · Satisfaction guaranteed</span>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Product Main",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "richtext",
      "id": "description_override",
      "label": "Description Override",
      "info": "Overrides the default product description when set."
    },
    {
      "type": "checkbox",
      "id": "show_compare_price",
      "label": "Show compare-at price",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature Item",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon",
          "default": "✓"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Feature Text",
          "default": "Feature description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Main",
      "settings": {
        "show_compare_price": true
      },
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "✓",
            "text": "Adjustable fit — works for all body types"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "✓",
            "text": "Breathable, lightweight material"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "✓",
            "text": "Wear under or over clothing"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "✓",
            "text": "Free Posture Mastery Course included"
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "✓",
            "text": "30-day money-back guarantee"
          }
        }
      ]
    }
  ]
}
{% endschema %}
