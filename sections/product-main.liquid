<section class="product-section section-padding" id="product-section">
  <div class="container">
    {%- assign product = section.settings.product -%}
    {%- if product == blank -%}
      {%- assign product = product -%}
    {%- endif -%}

    <div class="product-grid">
      <!-- LEFT: Image Gallery -->
      <div class="product-gallery animate-in">
        <div class="product-main-image">
          {% if product.featured_image %}
            <img src="{{ product.featured_image | image_url: width: 800 }}" alt="{{ product.featured_image.alt | escape }}" id="product-main-img">
          {% else %}
            <div style="aspect-ratio:1;background:var(--bg-card);display:flex;align-items:center;justify-content:center;color:var(--text-dim);border-radius:var(--radius-md);">Product Image</div>
          {% endif %}
          {% if product.images.size > 1 %}
            <button class="gallery-arrow gallery-arrow--prev" type="button" aria-label="Previous image">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button class="gallery-arrow gallery-arrow--next" type="button" aria-label="Next image">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
            </button>
          {% endif %}
        </div>
        {% if product.images.size > 1 %}
          <div class="product-thumbnails">
            {% for image in product.images %}
              <button class="product-thumbnail {% if forloop.first %}is-active{% endif %}"
                      data-full="{{ image | image_url: width: 800 }}"
                      data-index="{{ forloop.index0 }}">
                <img src="{{ image | image_url: width: 150 }}" alt="{{ image.alt | escape }}" loading="lazy">
              </button>
            {% endfor %}
          </div>
        {% endif %}
      </div>

      <!-- RIGHT: Product Info -->
      <div class="product-info animate-in" id="product-buy">
        <h2 class="product-title">{% if product.title != blank %}{{ product.title }}{% else %}FrameFix Strap{% endif %}</h2>

        <!-- Star Rating -->
        <div class="product-rating">
          {% for i in (1..5) %}
            {% render 'svg-icons', icon: 'star' %}
          {% endfor %}
          <span>({{ section.settings.review_count }})</span>
        </div>

        <!-- Price -->
        <div class="product-price">
          <span class="product-price__compare" id="product-compare-price" {% unless product.compare_at_price > product.price %}style="display:none"{% endunless %}>{{ product.compare_at_price | money }}</span>
          <span class="product-price__current" id="product-current-price">{% if product.price %}{{ product.price | money }}{% else %}$49.95{% endif %}</span>
        </div>

        <!-- Short description -->
        <p class="product-description-short">{{ section.settings.short_description }}</p>

        <!-- Product Form -->
        <form action="/cart/add" method="post" class="add-to-cart-form" id="add-to-cart-form">

          <!-- Color Selector -->
          {% assign color_option = nil %}
          {% for option in product.options_with_values %}
            {% assign option_name_lower = option.name | downcase %}
            {% if option_name_lower == 'color' or option_name_lower == 'colour' %}
              {% assign color_option = option %}
            {% endif %}
          {% endfor %}
          {% if color_option %}
            <div class="variant-group">
              <label class="variant-label">{{ color_option.name }}</label>
              <div class="color-swatches">
                {% for value in color_option.values %}
                  <button type="button" class="color-swatch {% if forloop.first %}is-active{% endif %}"
                          data-option-name="{{ color_option.name }}"
                          data-value="{{ value }}"
                          style="background-color: {{ value | downcase | replace: ' ', '' }};"
                          aria-label="{{ value }}">
                  </button>
                {% endfor %}
              </div>
            </div>
          {% endif %}

          <!-- Size Selector -->
          {% assign size_option = nil %}
          {% for option in product.options_with_values %}
            {% assign option_name_lower = option.name | downcase %}
            {% if option_name_lower == 'size' %}
              {% assign size_option = option %}
            {% endif %}
          {% endfor %}
          {% if size_option %}
            <div class="variant-group">
              <label class="variant-label">{{ size_option.name }}</label>
              <div class="size-options">
                {% for value in size_option.values %}
                  <button type="button" class="size-option {% if forloop.first %}is-active{% endif %}"
                          data-option-name="{{ size_option.name }}"
                          data-value="{{ value }}">{{ value }}</button>
                {% endfor %}
              </div>
              <p class="size-note">{{ section.settings.size_note }}</p>
            </div>
          {% elsif product == blank %}
            <!-- Fallback size buttons when no product selected -->
            <div class="variant-group">
              <label class="variant-label">Size</label>
              <div class="size-options">
                <button type="button" class="size-option is-active" data-option-name="Size" data-value="S">S</button>
                <button type="button" class="size-option" data-option-name="Size" data-value="M">M</button>
                <button type="button" class="size-option" data-option-name="Size" data-value="L">L</button>
                <button type="button" class="size-option" data-option-name="Size" data-value="XL">XL</button>
              </div>
              <p class="size-note">{{ section.settings.size_note }}</p>
            </div>
          {% endif %}

          <!-- Bundle Packs / Quantity -->
          {% if section.settings.show_bundles %}
            {%- assign base_price = product.price | default: 4995 -%}
            {%- assign disc2 = section.settings.bundle_2_discount -%}
            {%- assign disc3 = section.settings.bundle_3_discount -%}
            {%- assign save2_cents = base_price | times: disc2 | divided_by: 100 -%}
            {%- assign each2 = base_price | minus: save2_cents -%}
            {%- assign total2 = each2 | times: 2 -%}
            {%- assign save3_cents = base_price | times: disc3 | divided_by: 100 -%}
            {%- assign each3 = base_price | minus: save3_cents -%}
            {%- assign total3 = each3 | times: 3 -%}
            <div class="variant-group bundle-group">
              <label class="variant-label">Choose Your Pack</label>
              <div class="bundle-options">

                <button type="button" class="bundle-option is-active" data-qty="1">
                  <div class="bundle-option__left">
                    <span class="bundle-option__count">1×</span>
                    <span class="bundle-option__name">{{ section.settings.bundle_1_label }}</span>
                  </div>
                  <div class="bundle-option__right">
                    <span class="bundle-option__total">{{ base_price | money }}</span>
                    <span class="bundle-option__per"></span>
                  </div>
                </button>

                <button type="button" class="bundle-option" data-qty="2">
                  {% if disc2 > 0 %}<span class="bundle-badge">Save {{ disc2 }}%</span>{% endif %}
                  <div class="bundle-option__left">
                    <span class="bundle-option__count">2×</span>
                    <span class="bundle-option__name">{{ section.settings.bundle_2_label }}</span>
                  </div>
                  <div class="bundle-option__right">
                    <span class="bundle-option__total">{{ total2 | money }}</span>
                    <span class="bundle-option__per">{{ each2 | money }} each</span>
                  </div>
                </button>

                <button type="button" class="bundle-option" data-qty="3">
                  {% if disc3 > 0 %}<span class="bundle-badge bundle-badge--best">Save {{ disc3 }}%</span>{% endif %}
                  <div class="bundle-option__left">
                    <span class="bundle-option__count">3×</span>
                    <span class="bundle-option__name">{{ section.settings.bundle_3_label }}</span>
                  </div>
                  <div class="bundle-option__right">
                    <span class="bundle-option__total">{{ total3 | money }}</span>
                    <span class="bundle-option__per">{{ each3 | money }} each</span>
                  </div>
                </button>

              </div>
              {% if section.settings.bundle_note != blank %}
                <p class="bundle-note">{{ section.settings.bundle_note }}</p>
              {% endif %}
            </div>
          {% else %}
            <div class="variant-group">
              <label class="variant-label">Quantity</label>
              <div class="quantity-selector">
                <button type="button" class="qty-btn" data-action="decrease" aria-label="Decrease quantity">−</button>
                <input type="text" class="qty-input" value="1" min="1" max="10" readonly aria-label="Quantity">
                <button type="button" class="qty-btn" data-action="increase" aria-label="Increase quantity">+</button>
              </div>
            </div>
          {% endif %}

          <!-- Hidden variant input -->
          <input type="hidden" name="id" value="{% if product.selected_or_first_available_variant %}{{ product.selected_or_first_available_variant.id }}{% endif %}">
          <input type="hidden" name="quantity" value="1" class="qty-hidden">

          <!-- Add to Cart -->
          <button type="submit" class="btn-primary btn-primary--full add-to-cart-btn">
            <span class="btn-text">Add to Cart</span>
            <span class="spinner"></span>
          </button>
        </form>

        <!-- Checkout Trust -->
        <div class="checkout-trust">
          <div class="checkout-trust__item">
            {% render 'svg-icons', icon: 'lock' %}
            <span>Secure Checkout</span>
          </div>
          <div class="checkout-trust__item">
            {% render 'svg-icons', icon: 'refresh' %}
            <span>Fast Delivery</span>
          </div>
          <div class="checkout-trust__item">
            {% render 'svg-icons', icon: 'package' %}
            <span>Free Shipping</span>
          </div>
        </div>

        <!-- Features -->
        <ul class="product-features">
          {% for block in section.blocks %}
            {% if block.type == 'feature' %}
              <li {{ block.shopify_attributes }}>
                {% render 'svg-icons', icon: 'check' %}
                <span>{{ block.settings.text }}</span>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      </div>
    </div>

    <!-- Product Variants JSON for JS -->
    {% if product.variants %}
      <script>
        window.productVariants = [
          {% for variant in product.variants %}
            {
              id: {{ variant.id }},
              title: {{ variant.title | json }},
              price: {{ variant.price }},
              compare_at_price: {{ variant.compare_at_price | default: 0 }},
              available: {{ variant.available }},
              options: {{ variant.options | json }},
              featured_image: {% if variant.featured_image %}{{ variant.featured_image | image_url: width: 800 | json }}{% else %}null{% endif %}
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ];
      </script>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Product Main",
  "tag": "section",
  "class": "product-main-section",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "textarea",
      "id": "short_description",
      "label": "Short Description",
      "default": "Retrains your posture. Sharpens your jawline appearance. Builds a stronger frame. Posture Mastery Course included with purchase."
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review Count",
      "default": "120+ reviews"
    },
    {
      "type": "text",
      "id": "size_note",
      "label": "Size Note",
      "default": "Runs small — we recommend sizing up. This product is unisex."
    },
    {
      "type": "checkbox",
      "id": "show_compare_price",
      "label": "Show Compare at Price",
      "default": true
    },
    {
      "type": "header",
      "content": "Bundle Packs"
    },
    {
      "type": "checkbox",
      "id": "show_bundles",
      "label": "Show bundle pack selector",
      "default": true
    },
    {
      "type": "text",
      "id": "bundle_1_label",
      "label": "1-Pack label",
      "default": "Standard"
    },
    {
      "type": "text",
      "id": "bundle_2_label",
      "label": "2-Pack label",
      "default": "Most Popular"
    },
    {
      "type": "number",
      "id": "bundle_2_discount",
      "label": "2-Pack discount %",
      "default": 10
    },
    {
      "type": "text",
      "id": "bundle_3_label",
      "label": "3-Pack label",
      "default": "Best Value"
    },
    {
      "type": "number",
      "id": "bundle_3_discount",
      "label": "3-Pack discount %",
      "default": 20
    },
    {
      "type": "text",
      "id": "bundle_note",
      "label": "Bundle note text",
      "default": "Multi-pack discounts applied automatically at checkout."
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Feature Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Main",
      "settings": {
        "short_description": "Retrains your posture. Sharpens your jawline appearance. Builds a stronger frame. Posture Mastery Course included with purchase.",
        "review_count": "120+ reviews",
        "size_note": "Runs small — we recommend sizing up. This product is unisex.",
        "show_compare_price": true
      },
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "text": "Adjustable design — fits all body types"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Breathable, lightweight material for all-day comfort"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Discreet — wear under or over clothing"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Posture Mastery Course included with purchase (digital)"
          }
        }
      ]
    }
  ]
}
{% endschema %}
