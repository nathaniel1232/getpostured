          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What's included with my order?",
            "answer": "The FrameFix Strap™ and the full Posture Mastery Course (digital PDF download sent via email after purchase)."
          }
        }
      ]
    }
  ]
}
{% endschema %}
