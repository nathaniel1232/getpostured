<section class="faq-section reveal" id="faq-section">
  <div class="container">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>

    <div class="faq-container">
      {%- for block in section.blocks -%}
        <div class="faq-item" {{ block.shopify_attributes }}>
          <button class="faq-question" aria-expanded="false">
            <span>{{ block.settings.question }}</span>
            <span class="faq-icon">+</span>
          </button>
          <div class="faq-answer">
            <p>{{ block.settings.answer }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.faq-question').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var item = this.closest('.faq-item');
        var isActive = item.classList.contains('active');

        item.closest('.faq-container').querySelectorAll('.faq-item').forEach(function (el) {
          el.classList.remove('active');
          el.querySelector('.faq-question').setAttribute('aria-expanded', 'false');
        });

        if (!isActive) {
          item.classList.add('active');
          this.setAttribute('aria-expanded', 'true');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "How long should I wear it per day?",
            "answer": "Start with 15-30 minutes and gradually increase to 1-2 hours. The included course has a full 4-week plan."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Will this actually improve my jawline?",
            "answer": "Posture affects how your jawline appears by changing head and neck positioning. It won't change bone structure, but it can significantly sharpen how your features look."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Can I wear it under clothing?",
            "answer": "Yes. The FrameFix Strap is designed to be slim and discreet enough to wear under most shirts."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How long until I see results?",
            "answer": "Many people notice a difference in how they carry themselves within the first week. Visible, lasting improvement typically takes 2-4 weeks of consistent use."
          }
