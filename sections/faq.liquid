<section class="faq-section section-padding" id="faq-section">
  <div class="container">
    <h2 class="section-heading animate-in">{{ section.settings.heading }}</h2>
    <div class="faq-container">
      {% for block in section.blocks %}
        <div class="faq-item animate-in" {{ block.shopify_attributes }}>
          <button class="faq-question" aria-expanded="false">
            <span class="faq-question__text">{{ block.settings.question }}</span>
            <span class="faq-question__icon">
              {% render 'svg-icons', icon: 'chevron-down' %}
            </span>
          </button>
          <div class="faq-answer">
            <div class="faq-answer__inner">{{ block.settings.answer }}</div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Questions? We've Got Answers."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "How long should I wear it each day?",
            "answer": "<p>Start with 15-30 minutes in your first week. Gradually increase to 1-2 hours. The included Posture Course has a detailed 4-week plan.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Will this improve my jawline?",
            "answer": "<p>Posture affects how your jawline appears by changing head and neck positioning. It won't change bone structure, but proper alignment can significantly sharpen how your features look.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Can I wear it under my clothes?",
            "answer": "<p>Yes. The FrameFix Strap is slim and lightweight enough to wear discreetly under most shirts.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "How quickly will I see results?",
            "answer": "<p>Most people notice a difference in how they carry themselves within the first week. Visible, lasting change typically takes 2-4 weeks of consistent use with the exercises in the included course.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What size should I order?",
            "answer": "<p>S: chest 70-86 cm / M: 86-96 cm / L: 96-107 cm / XL: 107-122 cm. The strap runs small and is unisex — we recommend sizing up if you're between sizes.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Is there a money-back guarantee?",
            "answer": "<p>Yes. Full 30-day money-back guarantee. If you're not satisfied, contact us for a hassle-free refund.</p>"
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "What's included in my order?",
            "answer": "<p>You receive the FrameFix Strap and the full Posture Mastery Course (a digital PDF sent to your email after purchase).</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
