<section class="final-cta reveal" id="final-cta">
  <div class="container">
    <h2 class="section-heading">{{ section.settings.heading }}</h2>
    <p class="section-subheading">{{ section.settings.subheading }}</p>
    <a href="{{ section.settings.button_link }}" class="btn-primary btn-primary--large">{{ section.settings.button_text }}</a>
    {% render 'trust-badges' %}
  </div>
</section>

{% schema %}
{
  "name": "Final CTA",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Frame Starts Here"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "FrameFix Strap™ + Posture Course. Everything you need to stand taller, look sharper, and carry yourself with confidence."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Get Yours Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "#product-section"
    }
  ],
  "presets": [
    {
      "name": "Final CTA"
    }
  ]
}
{% endschema %}
