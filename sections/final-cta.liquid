<section class="final-cta section-padding" id="final-cta">
  <div class="container" style="text-align:center;">
    <h2 class="final-cta__heading animate-in">{{ section.settings.heading }}</h2>
    <p class="final-cta__subheading animate-in">{{ section.settings.subheading }}</p>
    <a href="{{ section.settings.button_link }}" class="btn-primary btn-primary--pill btn-primary--large animate-in">{{ section.settings.button_text }}</a>
    <div class="final-cta__trust animate-in">
      {% render 'trust-badges' %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Final CTA",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Frame Starts Here"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "FrameFix Strap + Posture Course. Stand taller, look sharper, carry yourself with confidence."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Get Yours Now →"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "default": "#product-section"
    }
  ],
  "presets": [
    {
      "name": "Final CTA"
    }
  ]
}
{% endschema %}
