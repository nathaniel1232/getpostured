<section class="how-it-works section-padding" id="how-it-works">
  <div class="container">
    <h2 class="section-heading animate-in">{{ section.settings.heading }}</h2>
    <div class="steps-grid stagger-children">
      {% for block in section.blocks %}
        <div class="step-card animate-in" {{ block.shopify_attributes }}>
          <div class="step-number">{{ forloop.index }}</div>
          <h3 class="step-title">{{ block.settings.title }}</h3>
          <p class="step-text">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How It Works",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Three Steps to Better Posture"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Put it on",
            "description": "<p>Wear it like a backpack. Adjust the straps until it's snug but comfortable.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Train your body",
            "description": "<p>The strap gently holds your shoulders back. Your muscles learn correct alignment over time.</p>"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "See the change",
            "description": "<p>Within weeks, your posture improves. Your frame, jawline appearance, and confidence follow.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
