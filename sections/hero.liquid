<section class="hero" id="hero-section">
  <div class="hero__content reveal">
    <h1 class="hero__title">{{ section.settings.heading }}</h1>
    <p class="hero__subtitle">{{ section.settings.subheading }}</p>
    <a href="{{ section.settings.button_link }}" class="btn-primary">{{ section.settings.button_text }}</a>
    {% render 'trust-badges' %}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Fix Your Posture. Sharpen Your Frame."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "The FrameFix Strap™ trains your body into proper alignment — improving your jawline appearance, height, confidence, and overall frame."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Shop Now"
    },
    {
      "type": "text",
      "id": "button_link",
      "label": "Button link",
      "default": "#product-section"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
