<section class="main-cart section-padding" id="main-content">
  <div class="container">

    <h1 class="section-heading">Your Cart</h1>

    {%- if cart.item_count == 0 -%}
      <div class="cart-empty">
        <p class="cart-empty__text">Your cart is empty.</p>
        <a href="/collections/all" class="btn-primary">Continue Shopping</a>
      </div>
    {%- else -%}
      <form action="/cart" method="post" class="cart-form" id="cart-form">

        <div class="cart-layout">

          <!-- Line items -->
          <div class="cart-items">
            {%- for item in cart.items -%}
              <div class="cart-item" data-variant-id="{{ item.variant_id }}">

                <a href="{{ item.url }}" class="cart-item__image-link">
                  {%- if item.image -%}
                    <img
                      class="cart-item__image"
                      src="{{ item.image | image_url: width: 160 }}"
                      alt="{{ item.image.alt | escape }}"
                      width="80"
                      height="80"
                      loading="lazy"
                    >
                  {%- endif -%}
                </a>

                <div class="cart-item__details">
                  <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                  {%- unless item.product.has_only_default_variant -%}
                    <p class="cart-item__variant">{{ item.variant.title }}</p>
                  {%- endunless -%}
                  {%- if item.original_line_price != item.final_line_price -%}
                    <p class="cart-item__price cart-item__price--sale">
                      <s>{{ item.original_line_price | money }}</s>
                      {{ item.final_line_price | money }}
                    </p>
                  {%- else -%}
                    <p class="cart-item__price">{{ item.original_line_price | money }}</p>
                  {%- endif -%}
                </div>

                <div class="cart-item__quantity-wrapper">
                  <label class="visually-hidden" for="quantity_{{ item.variant_id }}">Quantity</label>
                  <div class="quantity-selector">
                    <button
                      class="quantity-btn"
                      type="button"
                      data-action="decrease"
                      data-variant="{{ item.variant_id }}"
                      aria-label="Decrease quantity"
                    >−</button>
                    <input
                      class="quantity-input"
                      type="number"
                      id="quantity_{{ item.variant_id }}"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      min="0"
                      aria-label="Quantity for {{ item.product.title | escape }}"
                    >
                    <button
                      class="quantity-btn"
                      type="button"
                      data-action="increase"
                      data-variant="{{ item.variant_id }}"
                      aria-label="Increase quantity"
                    >+</button>
                  </div>
                  <a
                    href="{{ item.url_to_remove }}"
                    class="cart-item__remove"
                    aria-label="Remove {{ item.product.title | escape }}"
                  >Remove</a>
                </div>

              </div>
            {%- endfor -%}
          </div>

          <!-- Order summary -->
          <div class="cart-summary">
            <div class="cart-summary__inner">
              <h2 class="cart-summary__title">Order Summary</h2>

              {%- if cart.cart_level_discount_applications.size > 0 -%}
                <div class="cart-summary__discounts">
                  {%- for discount in cart.cart_level_discount_applications -%}
                    <div class="cart-summary__discount-row">
                      <span>{{ discount.title }}</span>
                      <span class="cart-summary__discount-amount">−{{ discount.total_allocated_amount | money }}</span>
                    </div>
                  {%- endfor -%}
                </div>
              {%- endif -%}

              <div class="cart-summary__row">
                <span>Subtotal</span>
                <span class="cart-summary__subtotal">{{ cart.total_price | money }}</span>
              </div>
              <p class="cart-summary__note">Taxes and shipping calculated at checkout</p>

              <button type="submit" name="checkout" class="btn-primary btn-primary--full cart-checkout-btn">
                Checkout — {{ cart.total_price | money }}
              </button>

              <a href="/collections/all" class="cart-continue-link">← Continue Shopping</a>
            </div>
          </div>

        </div>

      </form>
    {%- endif -%}

  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.quantity-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var action = this.dataset.action;
        var input = this.closest('.quantity-selector').querySelector('.quantity-input');
        var current = parseInt(input.value, 10) || 0;
        if (action === 'increase') {
          input.value = current + 1;
        } else if (action === 'decrease') {
          input.value = Math.max(0, current - 1);
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Cart",
  "settings": [],
  "presets": [
    {
      "name": "Cart"
    }
  ]
}
{% endschema %}
