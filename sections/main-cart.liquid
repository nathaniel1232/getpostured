<section class="main-cart section-padding" id="main-content">
  <div class="container">

    <h1 class="section-heading">Your Cart</h1>

    {%- if cart.item_count == 0 -%}
      <div class="cart-empty">
        <p class="cart-empty__text">Your cart is empty.</p>
        <a href="/collections/all" class="btn-primary">Continue Shopping</a>
      </div>
    {%- else -%}

      <div class="cart-layout" id="cart-layout">

        <!-- Line items -->
        <div class="cart-items" id="cart-items">
          {%- for item in cart.items -%}
            <div class="cart-item" data-line="{{ forloop.index }}" data-unit-price="{{ item.price }}" data-variant-id="{{ item.variant_id }}">

              <a href="{{ item.url }}" class="cart-item__image-link">
                {%- if item.image -%}
                  <img
                    class="cart-item__image"
                    src="{{ item.image | image_url: width: 160 }}"
                    alt="{{ item.image.alt | escape }}"
                    width="80"
                    height="80"
                    loading="lazy"
                  >
                {%- endif -%}
              </a>

              <div class="cart-item__details">
                <a href="{{ item.url }}" class="cart-item__title">{{ item.product.title }}</a>
                {%- unless item.product.has_only_default_variant -%}
                  <p class="cart-item__variant">{{ item.variant.title }}</p>
                {%- endunless -%}
                <p class="cart-item__price" data-line-price>
                  {%- if item.original_line_price != item.final_line_price -%}
                    <s class="cart-item__price--compare">{{ item.original_line_price | money }}</s>
                    {{ item.final_line_price | money }}
                  {%- else -%}
                    {{ item.original_line_price | money }}
                  {%- endif -%}
                </p>
              </div>

              <div class="cart-item__quantity-wrapper">
                <div class="quantity-selector">
                  <button class="quantity-btn" type="button" data-action="decrease" aria-label="Decrease quantity">−</button>
                  <input
                    class="quantity-input"
                    type="number"
                    value="{{ item.quantity }}"
                    min="0"
                    data-line="{{ forloop.index }}"
                    aria-label="Quantity"
                  >
                  <button class="quantity-btn" type="button" data-action="increase" aria-label="Increase quantity">+</button>
                </div>
                <button
                  class="cart-item__remove"
                  type="button"
                  data-line="{{ forloop.index }}"
                  aria-label="Remove {{ item.product.title | escape }}"
                >Remove</button>
              </div>

            </div>
          {%- endfor -%}
        </div>

        <!-- Order summary -->
        <div class="cart-summary">
          <div class="cart-summary__inner">
            <h2 class="cart-summary__title">Order Summary</h2>

            <div class="cart-summary__row">
              <span>Subtotal</span>
              <span class="cart-summary__subtotal" id="cart-subtotal">{{ cart.total_price | money }}</span>
            </div>
            <p class="cart-summary__note">Taxes and shipping calculated at checkout</p>

            <a href="/checkout" class="btn-primary btn-primary--full cart-checkout-btn" id="cart-checkout-btn">
              Checkout — <span id="cart-checkout-price">{{ cart.total_price | money }}</span>
            </a>

            <a href="/collections/all" class="cart-continue-link">← Continue Shopping</a>
          </div>
        </div>

      </div>

    {%- endif -%}

  </div>
</section>

<script>
(function () {
  /* ── helpers ─────────────────────────────────────────── */
  function money(cents) {
    var sym = window.Shopify && Shopify.currency && Shopify.currency.active
      ? Shopify.currency.active : '';
    var amount = (cents / 100).toFixed(2);
    // Use the shop money_format. Fallback to $X.XX
    return sym === 'USD' || sym === '' ? '$' + amount : amount + ' ' + sym;
  }

  function updateTotals(cart) {
    var subtotalEl       = document.getElementById('cart-subtotal');
    var checkoutPriceEl  = document.getElementById('cart-checkout-price');
    if (subtotalEl)      subtotalEl.textContent      = money(cart.total_price);
    if (checkoutPriceEl) checkoutPriceEl.textContent = money(cart.total_price);
  }

  function changeLineQty(line, quantity) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ line: line, quantity: quantity })
    })
    .then(function (r) { return r.json(); })
    .then(function (cart) {
      updateTotals(cart);

      /* update individual line price */
      var item = document.querySelector('.cart-item[data-line="' + line + '"]');
      if (item) {
        var unitPrice = parseInt(item.getAttribute('data-unit-price'), 10) || 0;
        var linePriceEl = item.querySelector('[data-line-price]');
        if (linePriceEl) {
          linePriceEl.textContent = money(unitPrice * quantity);
        }
        /* hide row if qty is 0 */
        if (quantity <= 0) {
          item.style.display = 'none';
        }
      }

      /* if cart is empty, show empty state */
      if (cart.item_count === 0) {
        location.reload();
      }
    })
    .catch(function (err) {
      console.error('Cart update failed', err);
    });
  }

  /* ── quantity buttons ────────────────────────────────── */
  document.querySelectorAll('.cart-item').forEach(function (item) {
    var line  = parseInt(item.getAttribute('data-line'), 10);
    var input = item.querySelector('.quantity-input');

    item.querySelectorAll('.quantity-btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var current = parseInt(input.value, 10) || 0;
        var next = btn.getAttribute('data-action') === 'increase'
          ? current + 1
          : Math.max(0, current - 1);
        input.value = next;
        changeLineQty(line, next);
      });
    });

    /* ── remove button ───────────────────────────────────── */
    var removeBtn = item.querySelector('.cart-item__remove');
    if (removeBtn) {
      removeBtn.addEventListener('click', function () {
        changeLineQty(line, 0);
      });
    }

    /* ── direct input edit ───────────────────────────────── */
    var debounceTimer;
    if (input) {
      input.addEventListener('change', function () {
        var qty = Math.max(0, parseInt(this.value, 10) || 0);
        this.value = qty;
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(function () {
          changeLineQty(line, qty);
        }, 400);
      });
    }
  });
})();
</script>

{% schema %}
{
  "name": "Cart",
  "settings": [],
  "presets": [
    {
      "name": "Cart"
    }
  ]
}
{% endschema %}

{% endschema %}
