<header class="site-header" data-header>
  <div class="header__inner">
    <a href="/" class="header__logo">{{ section.settings.brand_name }}</a>

    <nav class="header__nav desktop-only">
      {% for block in section.blocks %}
        <a href="{{ block.settings.url }}" {{ block.shopify_attributes }}>{{ block.settings.text }}</a>
      {% endfor %}
    </nav>

    <div class="header__actions">
      <a href="/cart" class="header__cart">
        {% render 'svg-icons', icon: 'cart' %}
        <span class="cart-count {% if cart.item_count > 0 %}has-items{% endif %}">{{ cart.item_count }}</span>
      </a>
      <button class="header__toggle mobile-only" aria-label="Menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
</header>

<div class="mobile-nav-overlay" data-nav-overlay></div>
<nav class="mobile-nav" data-mobile-nav>
  <button class="mobile-nav__close" aria-label="Close menu">
    {% render 'svg-icons', icon: 'close' %}
  </button>
  {% for block in section.blocks %}
    <a href="{{ block.settings.url }}" class="mobile-nav__link">{{ block.settings.text }}</a>
  {% endfor %}
  <a href="/cart" class="mobile-nav__link">Cart ({{ cart.item_count }})</a>
</nav>

{% schema %}
{
  "name": "Header",
  "class": "site-header-section",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand Name",
      "default": "POSTURED"
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Navigation Link",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Link Text"
        },
        {
          "type": "text",
          "id": "url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header",
      "blocks": [
        {
          "type": "nav_link",
          "settings": {
            "text": "Home",
            "url": "/"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "text": "Catalog",
            "url": "/collections/all"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "text": "About",
            "url": "#science-section"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "text": "FAQ",
            "url": "#faq-section"
          }
        }
      ]
    }
  ]
}
{% endschema %}
