<section class="problem-section" id="problem-section">
  <h2 class="section-title">{{ section.settings.heading }}</h2>

  <div class="problem-grid">
    {% for block in section.blocks %}
      <div class="problem-card reveal" {{ block.shopify_attributes }}>
        <span class="problem-card__icon">{{ block.settings.icon }}</span>
        <h3 class="problem-card__title">{{ block.settings.title }}</h3>
        <p class="problem-card__description">{{ block.settings.description }}</p>
      </div>
    {% endfor %}
  </div>

  <p class="problem-section__bottom-text">{{ section.settings.bottom_text }}</p>
</section>

{% schema %}
{
  "name": "Problem Cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Posture Is Holding You Back"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom text",
      "default": "The good news? This is fixable. And it starts with awareness."
    }
  ],
  "blocks": [
    {
      "type": "problem_card",
      "name": "Problem Card",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon / Emoji",
          "default": "🦴"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Forward Head Posture"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Pushes your jaw forward, compressing your jawline and making it appear less defined."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Problem Cards",
      "blocks": [
        {
          "type": "problem_card",
          "settings": {
            "icon": "🦴",
            "title": "Forward Head Posture",
            "description": "Pushes your jaw forward, compressing your jawline and making it appear less defined."
          }
        },
        {
          "type": "problem_card",
          "settings": {
            "icon": "🧍",
            "title": "Slouched Shoulders",
            "description": "Makes you look shorter, less confident, and closed off. Weakens your upper back over time."
          }
        },
        {
          "type": "problem_card",
          "settings": {
            "icon": "💪",
            "title": "Weak Frame",
            "description": "Poor posture signals low energy and low confidence — before you even say a word."
          }
        }
      ]
    }
  ]
}
{% endschema %}
