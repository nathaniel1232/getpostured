<section class="problem-section section-padding" id="problem-section">
  <div class="container">
    <h2 class="section-heading animate-in">{{ section.settings.heading }}</h2>
    <div class="problem-grid stagger-children">
      {% for block in section.blocks %}
        <div class="problem-card animate-in" {{ block.shopify_attributes }}>
          <div class="problem-card__icon">
            {% render 'svg-icons', icon: block.settings.icon %}
          </div>
          <h3 class="problem-card__title">{{ block.settings.title }}</h3>
          <p class="problem-card__text">{{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
    <p class="problem-section__bottom animate-in">{{ section.settings.bottom_text }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Problem Cards",
  "class": "problem-cards-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Your Posture Is Holding You Back"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom Text",
      "default": "The good news? This is completely fixable."
    }
  ],
  "blocks": [
    {
      "type": "problem_card",
      "name": "Problem Card",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon Name",
          "info": "Name passed to svg-icons snippet (e.g. crosshair, arrow-down, shield)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Problem Cards",
      "blocks": [
        {
          "type": "problem_card",
          "settings": {
            "icon": "crosshair",
            "title": "Forward Head Posture",
            "description": "Pushes your head forward, compressing the tissue under your chin. Your jawline appears less defined \u2014 not because of fat or genetics, but positioning."
          }
        },
        {
          "type": "problem_card",
          "settings": {
            "icon": "arrow-down",
            "title": "Slouched Shoulders",
            "description": "Makes you look shorter, less confident, and closed off. Over time it weakens your upper back and locks your body into this position."
          }
        },
        {
          "type": "problem_card",
          "settings": {
            "icon": "shield",
            "title": "Weak Frame",
            "description": "Poor posture signals low energy before you say a word. Your 'frame' \u2014 how you fill space \u2014 starts with how you stand."
          }
        }
      ]
    }
  ]
}
{% endschema %}
