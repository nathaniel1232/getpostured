      "default": "POSTURED"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Tagline",
      "default": "Fix your posture. Sharpen your frame."
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "© 2026 Postured — All rights reserved"
    }
  ],
  "blocks": [
    {
      "type": "link_group",
      "name": "Link group",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Group heading",
          "default": "Links"
        },
        {
          "type": "text",
          "id": "link_1_text",
          "label": "Link 1 text"
        },
        {
          "type": "url",
          "id": "link_1_url",
          "label": "Link 1 URL"
        },
        {
          "type": "text",
          "id": "link_2_text",
          "label": "Link 2 text"
        },
        {
          "type": "url",
          "id": "link_2_url",
          "label": "Link 2 URL"
        },
        {
          "type": "text",
          "id": "link_3_text",
          "label": "Link 3 text"
        },
        {
          "type": "url",
          "id": "link_3_url",
          "label": "Link 3 URL"
        },
        {
          "type": "text",
          "id": "link_4_text",
          "label": "Link 4 text"
        },
        {
          "type": "url",
          "id": "link_4_url",
          "label": "Link 4 URL"
        }
