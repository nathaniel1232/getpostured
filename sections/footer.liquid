<footer class="site-footer">
  <div class="container">
    <div class="footer__brand">{{ section.settings.brand_name }}</div>
    <nav class="footer__nav">
      {% for block in section.blocks %}
        {% if block.type == 'nav_link' %}
          <a href="{{ block.settings.url }}" {{ block.shopify_attributes }}>{{ block.settings.text }}</a>
        {% endif %}
      {% endfor %}
    </nav>
    <div class="footer__social">
      {% if settings.social_instagram != blank %}
        <a href="{{ settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
          {% render 'svg-icons', icon: 'instagram' %}
        </a>
      {% endif %}
      {% if settings.social_tiktok != blank %}
        <a href="{{ settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">
          {% render 'svg-icons', icon: 'tiktok' %}
        </a>
      {% endif %}
    </div>
    <p class="footer__copyright">{{ section.settings.copyright }}</p>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "POSTURED"
    },
    {
      "type": "text",
      "id": "copyright",
      "label": "Copyright text",
      "default": "© 2026 Postured — All rights reserved"
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Navigation Link",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Link text"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "nav_link",
          "settings": {
            "text": "Shop",
            "url": "/#product-section"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "text": "Catalog",
            "url": "/collections/all"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "text": "About",
            "url": "#science-section"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "text": "Contact",
            "url": "/pages/contact"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "text": "Shipping",
            "url": "/policies/shipping-policy"
          }
        },
        {
          "type": "nav_link",
          "settings": {
            "text": "Privacy Policy",
            "url": "/policies/privacy-policy"
          }
        }
      ]
    }
  ]
}
{% endschema %}
