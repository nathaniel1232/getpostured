<section class="ba-section section-padding" id="slider-section">
  <div class="container">
    <h2 class="section-heading animate-in">{{ section.settings.heading }}</h2>
    <div class="ba-slider animate-in" data-section-id="{{ section.id }}">
      <div class="ba-container">
        {% if section.settings.before_image %}
          <img class="ba-before" src="{{ section.settings.before_image | image_url: width: 1200 }}" alt="{{ section.settings.before_label }}" loading="lazy">
        {% else %}
          <div class="ba-before ba-placeholder">Before image placeholder</div>
        {% endif %}

        <div class="ba-after-wrapper">
          {% if section.settings.after_image %}
            <img class="ba-after" src="{{ section.settings.after_image | image_url: width: 1200 }}" alt="{{ section.settings.after_label }}" loading="lazy">
          {% else %}
            <div class="ba-after ba-placeholder">After image placeholder</div>
          {% endif %}
        </div>

        <div class="ba-handle">
          <div class="ba-handle-line"></div>
          <div class="ba-handle-circle">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M7 4L3 10L7 16" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M13 4L17 10L13 16" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>

        <span class="ba-label ba-label--before">{{ section.settings.before_label }}</span>
        <span class="ba-label ba-label--after">{{ section.settings.after_label }}</span>
      </div>
    </div>
    <p class="ba-hint animate-in">{{ section.settings.hint_text }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Before/After Slider",
  "tag": "section",
  "class": "ba-slider-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "See the Difference"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Before Image"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "After Image"
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "Before Label",
      "default": "Before"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "After Label",
      "default": "After"
    },
    {
      "type": "text",
      "id": "hint_text",
      "label": "Hint Text",
      "default": "Drag the slider to compare"
    }
  ],
  "presets": [
    {
      "name": "Before/After Slider",
      "settings": {
        "heading": "See the Difference",
        "before_label": "Before",
        "after_label": "After",
        "hint_text": "Drag the slider to compare"
      }
    }
  ]
}
{% endschema %}
