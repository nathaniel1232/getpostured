<section class="course-section section-padding" id="course-section">
  <div class="container">
    <h2 class="section-heading animate-in">{{ section.settings.heading }}</h2>
    <p class="section-subheading animate-in">{{ section.settings.subheading }}</p>
    <div class="course-layout">
      <div class="course-preview animate-in">
        {% if section.settings.course_image %}
          <img src="{{ section.settings.course_image | image_url: width: 600 }}" alt="Posture Mastery Course" loading="lazy">
        {% else %}
          <div class="course-preview__placeholder">
            <p style="font-family:var(--font-heading);font-size:24px;color:var(--text-primary);margin-bottom:8px;">Posture Mastery</p>
            <p style="font-size:13px;color:var(--text-dim);">Course Cover</p>
          </div>
        {% endif %}
      </div>
      <div class="course-info animate-in">
        <div class="course-chapters">
          {% for block in section.blocks %}
            <div class="course-chapter" {{ block.shopify_attributes }}>
              <div>
                <div class="course-chapter__title">{{ block.settings.title }}</div>
                {% if block.settings.subtitle != blank %}
                  <div class="course-chapter__subtitle">{{ block.settings.subtitle }}</div>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
        <p class="course-delivery">{{ section.settings.delivery_text }}</p>
        <a href="{{ section.settings.button_link }}" class="btn-primary course-cta">{{ section.settings.button_text }}</a>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Course Section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Included Free With Every Order"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "The Posture Mastery Course — a 5-chapter digital guide to fixing your posture for good."
    },
    {
      "type": "image_picker",
      "id": "course_image",
      "label": "Course Image"
    },
    {
      "type": "textarea",
      "id": "delivery_text",
      "label": "Delivery Text",
      "default": "Delivered as a digital PDF download with your order. No extra cost."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Get the Strap + Course →"
    },
    {
      "type": "text",
      "id": "button_link",
      "label": "Button Link",
      "default": "#product-section"
    }
  ],
  "blocks": [
    {
      "type": "chapter",
      "name": "Chapter",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Chapter Title",
          "default": "Chapter Title"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Chapter description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Course Section",
      "blocks": [
        {
          "type": "chapter",
          "settings": {
            "title": "Why Posture Matters",
            "subtitle": "Jawline, height, confidence, perception"
          }
        },
        {
          "type": "chapter",
          "settings": {
            "title": "What Goes Wrong",
            "subtitle": "Forward head posture, Upper Crossed Syndrome"
          }
        },
        {
          "type": "chapter",
          "settings": {
            "title": "The Hidden Effects",
            "subtitle": "Breathing, energy, mood, pain"
          }
        },
        {
          "type": "chapter",
          "settings": {
            "title": "How to Fix It",
            "subtitle": "FrameFix Strap guide, exercises, 4-week plan"
          }
        },
        {
          "type": "chapter",
          "settings": {
            "title": "Building the Habit",
            "subtitle": "Frame, consistency, long-term results"
          }
        }
      ]
    }
  ]
}
{% endschema %}
