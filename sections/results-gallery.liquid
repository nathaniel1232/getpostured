<section class="results-section section-padding" id="results-section">
  <div class="container">
    <h2 class="section-heading animate-in">{{ section.settings.heading }}</h2>
    <p class="section-subheading animate-in">{{ section.settings.subheading }}</p>
    <div class="results-grid stagger-children">
      {% for block in section.blocks %}
        <div class="result-card animate-in" {{ block.shopify_attributes }}>
          <div class="result-card__images">
            {% if block.settings.before_image %}
              <img src="{{ block.settings.before_image | image_url: width: 400 }}" alt="Before" loading="lazy">
            {% else %}
              <div class="result-card__placeholder">Before</div>
            {% endif %}
            {% if block.settings.after_image %}
              <img src="{{ block.settings.after_image | image_url: width: 400 }}" alt="After" loading="lazy">
            {% else %}
              <div class="result-card__placeholder">After</div>
            {% endif %}
          </div>
          <div class="result-card__body">
            <div class="result-card__stars">
              {% for i in (1..5) %}{% render 'svg-icons', icon: 'star' %}{% endfor %}
            </div>
            <p class="result-card__name">{{ block.settings.name }}</p>
            <p class="result-card__quote">"{{ block.settings.quote }}"</p>
          </div>
        </div>
      {% endfor %}
    </div>
    <p class="results-disclaimer animate-in">{{ section.settings.disclaimer }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Results Gallery",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real People, Real Results"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "See how the FrameFix Strap changed their posture and appearance."
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer",
      "default": "Results vary. Posture correction affects appearance through positioning, not bone structure."
    }
  ],
  "blocks": [
    {
      "type": "result",
      "name": "Result",
      "settings": [
        {
          "type": "image_picker",
          "id": "before_image",
          "label": "Before Image"
        },
        {
          "type": "image_picker",
          "id": "after_image",
          "label": "After Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Customer Name"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This product changed my posture completely."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Results Gallery",
      "blocks": [
        {
          "type": "result",
          "settings": {
            "name": "Marcus T.",
            "quote": "My jawline looks completely different now. It was my posture the whole time."
          }
        },
        {
          "type": "result",
          "settings": {
            "name": "Jake R.",
            "quote": "People keep telling me I look taller. I'm the same height — just standing properly."
          }
        },
        {
          "type": "result",
          "settings": {
            "name": "Dylan M.",
            "quote": "The course opened my eyes. The strap built the habit. Total game changer."
          }
        }
      ]
    }
  ]
}
{% endschema %}
