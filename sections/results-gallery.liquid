<div id="results-section" class="results-section">
  <div class="container">
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    <p class="section-subtitle">{{ section.settings.subheading }}</p>

    <div class="results-grid">
      {% for block in section.blocks %}
        <div class="result-card reveal" {{ block.shopify_attributes }}>
          <div class="result-card__images">
            {% if block.settings.before_image != blank %}
              <div class="result-card__image">
                <img
                  src="{{ block.settings.before_image | image_url: width: 400 }}"
                  alt="Before — {{ block.settings.name }}"
                  loading="lazy"
                  width="400"
                  height="500"
                >
              </div>
            {% else %}
              <div class="result-card__image result-card__placeholder">Before</div>
            {% endif %}

            {% if block.settings.after_image != blank %}
              <div class="result-card__image">
                <img
                  src="{{ block.settings.after_image | image_url: width: 400 }}"
                  alt="After — {{ block.settings.name }}"
                  loading="lazy"
                  width="400"
                  height="500"
                >
              </div>
            {% else %}
              <div class="result-card__image result-card__placeholder">After</div>
            {% endif %}
          </div>

          <h3 class="result-card__name">{{ block.settings.name }}</h3>
          <p class="result-card__quote"><em>"{{ block.settings.quote }}"</em></p>
        </div>
      {% endfor %}
    </div>

    <p class="results-disclaimer">{{ section.settings.disclaimer_text }}</p>
  </div>
</div>

<style>
  .results-section {
    padding: 80px 20px;
    background-color: #0a0a0a;
    color: #f0f0f0;
  }

  .results-section .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .results-section .section-title {
    text-align: center;
    font-size: 2.4rem;
    margin-bottom: 0.4em;
    color: #ffffff;
  }

  .results-section .section-subtitle {
    text-align: center;
    color: #999;
    font-size: 1.1rem;
    margin-bottom: 3rem;
  }

  .results-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .result-card {
    background: #141414;
    border: 1px solid #222;
    border-radius: 12px;
    overflow: hidden;
    padding-bottom: 1.5rem;
  }

  .result-card__images {
    display: flex;
    gap: 0;
  }

  .result-card__image {
    flex: 1;
    overflow: hidden;
  }

  .result-card__image img {
    width: 100%;
    height: 260px;
    object-fit: cover;
    display: block;
  }

  .result-card__placeholder {
    height: 260px;
    background: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #555;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .result-card__name {
    padding: 1.2rem 1.2rem 0.3rem;
    font-size: 1.1rem;
    color: #fff;
    margin: 0;
  }

  .result-card__quote {
    padding: 0 1.2rem;
    color: #aaa;
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0;
  }

  .results-disclaimer {
    text-align: center;
    color: #666;
    font-size: 0.8rem;
    margin-top: 2.5rem;
  }

  @media (max-width: 768px) {
    .results-grid {
      grid-template-columns: 1fr;
    }

    .results-section .section-title {
      font-size: 1.8rem;
    }
  }
</style>

{% schema %}
{
  "name": "Results Gallery",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real Results From Real People"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "See how posture correction changed their appearance and confidence."
    },
    {
      "type": "text",
      "id": "disclaimer_text",
      "label": "Disclaimer Text",
      "default": "Results vary. Posture affects appearance, not bone structure."
    }
  ],
  "blocks": [
    {
      "type": "result",
      "name": "Result Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "before_image",
          "label": "Before Image"
        },
        {
          "type": "image_picker",
          "id": "after_image",
          "label": "After Image"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Name"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This changed my life."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Results Gallery",
