<section class="science-section section-padding" id="science-section">
  <div class="container">
    <h2 class="section-heading animate-in">{{ section.settings.heading }}</h2>
    <p class="section-subheading animate-in">{{ section.settings.subheading }}</p>
    <div class="science-grid stagger-children">
      {% for block in section.blocks %}
        <div class="science-card animate-in" {{ block.shopify_attributes }}>
          <h3 class="science-card__title">{{ block.settings.title }}</h3>
          <p class="science-card__text">{{ block.settings.description }}</p>
          <p class="science-card__source">{{ block.settings.source }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Science Section",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why It Works"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Grounded in real research. Here's what science says about posture."
    }
  ],
  "blocks": [
    {
      "type": "science_card",
      "name": "Science Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Science Fact"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Description of the scientific finding."
        },
        {
          "type": "text",
          "id": "source",
          "label": "Source",
          "default": "Source"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Science Section",
      "blocks": [
        {
          "type": "science_card",
          "settings": {
            "title": "Jawline & Appearance",
            "description": "Forward head posture compresses tissue under the chin, making the jawline appear less defined. Proper alignment visibly sharpens your profile.",
            "source": "National Library of Medicine"
          }
        },
        {
          "type": "science_card",
          "settings": {
            "title": "Confidence & Perception",
            "description": "Upright posture is linked to higher confidence, stronger first impressions, and better mood.",
            "source": "Carney, Cuddy & Yap (2010); Health Psychology"
          }
        },
        {
          "type": "science_card",
          "settings": {
            "title": "Energy & Performance",
            "description": "Poor posture reduces lung capacity and increases fatigue. Correcting it improves breathing and energy.",
            "source": "Mayo Clinic; Journal of Physical Therapy Science"
          }
        }
      ]
    }
  ]
}
{% endschema %}
