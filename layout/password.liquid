<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ shop.name }} — Password Protected</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet">
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>
<body>
  <main id="main-content" class="password-page section-padding" role="main">
    <div class="container">
      <div class="customer-form-wrapper" style="max-width:480px;margin:0 auto;text-align:center;">
        <a href="/" class="header__logo" style="display:block;margin-bottom:32px;">{{ shop.name }}</a>
        <h1 class="customer-form__title">Coming Soon</h1>
        <p style="margin-bottom:32px;">{{ shop.password_message | default: 'This store is currently password-protected.' }}</p>

        {%- form 'storefront_password' -%}
          {%- if form.errors -%}
            <div class="form-errors" role="alert">
              <p>{{ 'general.password_page.login_error' | t }}</p>
            </div>
          {%- endif -%}
          <div class="form-group">
            <label class="form-label" for="Password">Password</label>
            <input
              class="form-input"
              type="password"
              name="password"
              id="Password"
              autocomplete="current-password"
              autofocus
            >
          </div>
          <button type="submit" class="btn-primary btn-primary--full">Enter Store</button>
        {%- endform -%}
      </div>
    </div>
  </main>
</body>
</html>
